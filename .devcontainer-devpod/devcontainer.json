{
  "name": "comunidad-devpod",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "user",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "21",
      "installMaven": "true",
      "additionalVersions": "17"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "forwardPorts": [8080, 3306],
  "remoteEnv": {
    "SDKMAN_DIR": "/usr/local/sdkman",
    "SDKMAN_CANDIDATES_DIR": "/usr/local/sdkman/candidates",
    "DB_URL": "jdbc:mysql://localhost:3306/comunidad_db",
    "DB_USER": "comunidad_user",
    "DB_PASSWORD": "comunidad_pass"
  },
  "postCreateCommand": "bash -c 'sudo chown -R 1000:1000 /home/user/.npm && sudo usermod -aG docker user && source /usr/local/sdkman/bin/sdkman-init.sh && java -version && mvn -version && sudo docker compose up -d'"
}
